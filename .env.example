# ─── AI Werewolf Environment Variables ───────────────────────────────────
# Copy this file to .env.local for local dev, and set these in the
# Netlify dashboard (Site settings → Environment variables) for production.

# ── Gemini API (free tier: 1,500 requests/day) ──
# Get a key at https://aistudio.google.com/apikey
# Used server-side by netlify/functions/genai-proxy.js
API_KEY=your_gemini_api_key_here

# ── Supabase — auth + game records + payment escrow ──
# Project URL from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# ── Supabase service_role key (server-side only — NEVER in frontend bundle) ──
# Used by payment-escrow Netlify function. Set this in Netlify dashboard.
# Local dev: payment-escrow uses test-mode fallback when this is missing.
SUPABASE_SERVICE_ROLE_KEY=

# ── CORS restriction (production) ──
# Comma-separated list of allowed origins for the AI proxy function.
# Leave empty for local dev (allows all). Set to your domain in production.
ALLOWED_ORIGIN=
